<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SplitDash — Real-Time Bill Splitter</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700;800&family=JetBrains+Mono:wght@400;700;800&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --ink: #0f172a;
    --paper: #f8fafc;
    --rose: #f43f5e;
    --indigo: #4f46e5;
    --yellow: #fbbf24;
    --green: #10b981;
    --orange: #f97316;
    --blue: #3b82f6;
    --pink: #ec4899;
    --slate2: #e2e8f0;
    --slate4: #94a3b8;
    --mono: 'JetBrains Mono', monospace;
  }
  body { font-family: 'Space Grotesk', sans-serif; background: var(--paper); color: var(--ink); min-height: 100vh; }
  .hide { display: none !important; }

  /* ─── GATEWAY ─── */
  #gateway {
    min-height: 100vh; display: flex; align-items: center; justify-content: center;
    background: var(--paper); padding: 1.5rem;
  }
  .gateway-card {
    max-width: 420px; width: 100%;
    background: #fff; border: 6px solid var(--ink); padding: 3rem;
    box-shadow: 18px 18px 0 var(--ink);
  }
  .logo { font-size: 4rem; font-weight: 900; letter-spacing: -0.05em; font-style: italic; line-height: 1; }
  .logo-sub { font-size: 0.6rem; font-weight: 800; letter-spacing: 0.2em; text-transform: uppercase; color: var(--indigo); margin-top: .5rem; }
  .btn { cursor: pointer; font-family: inherit; font-weight: 900; text-transform: uppercase; letter-spacing: 0.1em; font-size: 0.7rem; border: 4px solid var(--ink); padding: 1rem 1.5rem; transition: transform .1s, box-shadow .1s; }
  .btn:active { transform: translate(3px,3px); box-shadow: none !important; }
  .btn-dark { background: var(--ink); color: #fff; box-shadow: 4px 4px 0 var(--indigo); }
  .btn-light { background: #fff; color: var(--ink); box-shadow: 4px 4px 0 var(--ink); }
  .btn-yellow { background: var(--yellow); color: var(--ink); box-shadow: 4px 4px 0 var(--ink); }
  .btn-rose { background: var(--rose); color: #fff; box-shadow: 4px 4px 0 var(--ink); }
  .btn-block { width: 100%; display: flex; align-items: center; justify-content: space-between; }
  .btn-sm { padding: .5rem .9rem; font-size: .65rem; }
  input, textarea {
    font-family: inherit; font-weight: 700; font-size: 1rem;
    border: 4px solid var(--ink); padding: .75rem 1rem; width: 100%; outline: none;
    transition: background .15s;
  }
  input:focus, textarea:focus { background: #eef2ff; }
  label { font-size: 0.6rem; font-weight: 800; letter-spacing: 0.2em; text-transform: uppercase; color: var(--slate4); display: block; margin-bottom: .4rem; }
  .gateway-actions { display: flex; flex-direction: column; gap: .75rem; margin-top: 2rem; }
  .gateway-sub { font-size: .6rem; font-weight: 700; text-transform: uppercase; color: var(--slate4); font-style: italic; margin-top: .2rem; }
  .back-link { font-size: .65rem; font-weight: 800; text-transform: uppercase; letter-spacing: .1em; cursor: pointer; text-decoration: underline; color: var(--slate4); margin-top: 1rem; display: inline-block; }
  .form-pair { display: flex; gap: .75rem; margin-top: 1.5rem; }
  .form-pair .btn { flex: 1; text-align: center; justify-content: center; }

  /* ─── MAIN APP ─── */
  #app { display: none; }
  .header {
    border-bottom: 6px solid var(--ink); padding: 2rem 3rem 1.5rem;
    display: flex; justify-content: space-between; align-items: flex-end;
    max-width: 1400px; margin: 0 auto;
  }
  .header-title { font-size: 5rem; font-weight: 900; letter-spacing: -.05em; font-style: italic; line-height: 1; }
  .badge { background: var(--ink); color: #fff; font-size: .55rem; font-weight: 900; text-transform: uppercase; letter-spacing: .15em; padding: .2rem .5rem; transform: rotate(-6deg); display: inline-block; margin-left: .75rem; vertical-align: middle; margin-top: .5rem; }
  .group-code { font-size: .6rem; font-weight: 800; letter-spacing: .15em; text-transform: uppercase; color: var(--slate4); margin-top: .5rem; font-style: italic; }
  .group-code span { color: var(--indigo); background: #eef2ff; padding: .1rem .4rem; }
  .avatar-stack { display: flex; }
  .avatar {
    width: 2.8rem; height: 2.8rem; border-radius: 50%; border: 3px solid var(--paper);
    display: flex; align-items: center; justify-content: center;
    font-size: .65rem; font-weight: 900; color: #fff; margin-left: -1rem;
    cursor: pointer; transition: transform .2s; box-shadow: 0 2px 8px rgba(0,0,0,.25);
  }
  .avatar:first-child { margin-left: 0; }
  .avatar:hover { transform: translateY(-.5rem); }
  .live-badge { font-size: .6rem; font-weight: 900; text-transform: uppercase; letter-spacing: .1em; padding: .35rem .7rem; border: 2px solid; border-radius: 4px; display: flex; align-items: center; gap: .4rem; background: #dcfce7; color: #15803d; border-color: #86efac; }
  .pulse { width: .5rem; height: .5rem; border-radius: 50%; background: #22c55e; animation: pulse 1.5s infinite; }
  @keyframes pulse { 0%,100%{opacity:1}50%{opacity:.3} }

  .main-grid { max-width: 1400px; margin: 0 auto; padding: 2.5rem 3rem; display: grid; grid-template-columns: 1fr 380px; gap: 3rem; }
  @media(max-width: 1024px) { .main-grid { grid-template-columns: 1fr; } }

  /* ─── ITEMS ─── */
  .section-title { font-size: 2rem; font-weight: 900; letter-spacing: -.04em; font-style: italic; display: flex; align-items: center; gap: .75rem; }
  .toolbar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem; }
  .toolbar-btns { display: flex; gap: .5rem; flex-wrap: wrap; }
  .table-wrap { border: 4px solid var(--ink); box-shadow: 10px 10px 0 var(--ink); overflow: hidden; }
  .table-header { display: grid; grid-template-columns: 1fr 100px 200px; background: var(--ink); color: #fff; padding: 1rem 1.5rem; font-size: .6rem; font-weight: 900; text-transform: uppercase; letter-spacing: .2em; }
  .table-header div:nth-child(2) { text-align: right; }
  .table-header div:nth-child(3) { text-align: center; }
  .item-row {
    display: grid; grid-template-columns: 1fr 100px 200px;
    padding: .9rem 1.5rem; align-items: center; background: #fff;
    border-bottom: 2px solid #f1f5f9; position: relative;
    transition: background .15s;
  }
  .item-row:hover { background: #f0f4ff; }
  .item-row.locked { opacity: .55; background: #f8fafc; }
  .item-row .cat-bar {
    position: absolute; left: 0; top: 0; bottom: 0; width: 4px;
  }
  .cat-food { background: var(--orange); }
  .cat-drink { background: var(--blue); }
  .cat-dessert { background: var(--pink); }
  .item-name { font-weight: 900; font-size: .95rem; letter-spacing: -.02em; }
  .item-name.struck { text-decoration: line-through; color: var(--slate4); }
  .qty-controls { display: inline-flex; align-items: center; gap: .2rem; margin-left: .5rem; }
  .qty-btn {
    width: 1.3rem; height: 1.3rem; border: 2px solid var(--slate2); background: #f1f5f9;
    cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: .7rem; font-weight: 900;
    border-radius: 3px; transition: background .1s;
  }
  .qty-btn:hover { background: var(--slate2); }
  .qty-tag { font-size: .65rem; font-weight: 900; text-transform: uppercase; padding: .15rem .4rem; background: #f1f5f9; border: 1px solid var(--slate2); border-radius: 3px; }
  .claim-avatars { display: flex; margin-top: .4rem; gap: .2rem; flex-wrap: wrap; }
  .mini-avatar { width: 1.5rem; height: 1.5rem; border-radius: 50%; border: 2px solid #fff; display: flex; align-items: center; justify-content: center; font-size: .55rem; font-weight: 900; color: #fff; cursor: help; }
  .expiry-warn { font-size: .6rem; font-weight: 900; color: #ef4444; text-transform: uppercase; letter-spacing: .05em; animation: pulse 1s infinite; display: flex; align-items: center; gap: .3rem; margin-left: .5rem; }
  .price-col { text-align: right; }
  .price-main { font-family: var(--mono); font-weight: 800; font-size: 1rem; }
  .price-ea { font-size: .65rem; color: var(--slate4); font-weight: 700; text-transform: uppercase; }
  .action-col { display: flex; flex-direction: column; gap: .35rem; padding-left: 1rem; position: relative; }
  .action-btns { display: flex; gap: .3rem; }
  .claim-btn { flex: 1; padding: .5rem; font-size: .6rem; font-weight: 900; text-transform: uppercase; letter-spacing: .1em; cursor: pointer; border: none; font-family: inherit; transition: filter .15s; }
  .claim-btn:hover { filter: brightness(.9); }
  .btn-claim-full { background: var(--indigo); color: #fff; box-shadow: 2px 2px 0 var(--ink); }
  .btn-claim-split { background: #fff; color: var(--ink); border: 3px solid var(--ink) !important; }
  .claimed-tag { background: var(--green); color: #fff; font-size: .6rem; font-weight: 900; text-transform: uppercase; text-align: center; padding: .4rem; display: flex; align-items: center; justify-content: center; gap: .3rem; }
  .btn-undo-small { flex: 1; padding: .3rem; font-size: .55rem; font-weight: 900; text-transform: uppercase; cursor: pointer; border: 2px solid var(--ink); background: #fff; font-family: inherit; }
  .btn-lock-small { flex: 1; padding: .3rem; font-size: .55rem; font-weight: 900; text-transform: uppercase; cursor: pointer; border: 2px solid var(--ink); background: var(--ink); color: #fff; font-family: inherit; }
  .locked-tag { background: var(--ink); color: #fff; font-size: .6rem; font-weight: 900; text-transform: uppercase; text-align: center; padding: .5rem; display: flex; align-items: center; justify-content: center; gap: .3rem; }
  .split-popup {
    position: absolute; top: 3.5rem; right: 0; left: 0; z-index: 20;
    background: #fff; border: 4px solid var(--ink); padding: .75rem; box-shadow: 6px 6px 0 var(--ink);
  }
  .split-popup label { font-size: .6rem; margin-bottom: .3rem; }
  .split-popup-inner { display: flex; gap: .4rem; }
  .split-popup input { border: 2px solid var(--slate2); padding: .35rem .5rem; font-size: .8rem; }
  .split-popup .btn-xs { padding: .4rem .6rem; font-size: .6rem; background: var(--indigo); color: #fff; border: 2px solid var(--ink); cursor: pointer; font-family: inherit; font-weight: 900; }

  /* ─── TOTALS ─── */
  .totals-bar { background: var(--ink); color: #fff; padding: 2.5rem; border: 4px solid var(--ink); box-shadow: 10px 10px 0 var(--indigo); margin-top: 1.5rem; }
  .totals-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1.5rem; margin-bottom: 1.5rem; }
  .total-label { font-size: .65rem; font-weight: 900; text-transform: uppercase; letter-spacing: .15em; color: var(--slate4); margin-bottom: .5rem; }
  .total-value { font-family: var(--mono); font-size: 2rem; font-weight: 900; }
  .total-value.accent { color: #6ee7b7; }
  .grand-row { border-top: 6px solid rgba(79,70,229,.35); padding-top: 1.5rem; display: flex; align-items: center; justify-content: space-between; }
  .grand-label { font-size: 1.1rem; font-weight: 900; text-transform: uppercase; letter-spacing: .1em; color: #818cf8; }
  .grand-value { font-family: var(--mono); font-size: 4rem; font-weight: 900; line-height: 1; }

  /* ─── SIDEBAR ─── */
  .sidebar { display: flex; flex-direction: column; gap: 2rem; }
  .card { border: 4px solid var(--ink); background: #fff; }
  .card-dark { border: 4px solid var(--ink); background: var(--ink); color: #fff; }
  .card-head { font-size: .6rem; font-weight: 900; text-transform: uppercase; letter-spacing: .2em; padding: 1rem 1.5rem; border-bottom: 3px solid var(--slate2); }
  .card-dark .card-head { border-color: rgba(255,255,255,.15); }
  .card-body { padding: 1.5rem; }
  .progress-wrap { display: flex; align-items: center; gap: 1.5rem; }
  svg.ring { transform: rotate(-90deg); }
  .ring-track { fill: none; stroke: #1e293b; }
  .ring-fill { fill: none; stroke: #6366f1; stroke-linecap: round; transition: stroke-dashoffset .8s ease; }
  .ring-pct { font-family: var(--mono); font-size: 1.2rem; font-weight: 900; color: #fff; }
  .settled-amount { font-family: var(--mono); font-size: 2.2rem; font-weight: 900; font-style: italic; line-height: 1.1; }
  .settled-sub { font-size: .6rem; font-weight: 800; text-transform: uppercase; letter-spacing: .15em; color: var(--slate4); margin-top: .5rem; }

  /* leaderboard */
  .leader-list { padding: 1rem 1.5rem; }
  .leader-row { display: flex; align-items: center; gap: .75rem; padding: .75rem 0; border-bottom: 1px solid rgba(255,255,255,.08); }
  .leader-row:last-child { border-bottom: none; }
  .leader-rank { width: 2rem; height: 2rem; border-radius: 50%; background: #fff; color: var(--ink); display: flex; align-items: center; justify-content: center; font-size: .65rem; font-weight: 900; flex-shrink: 0; }
  .leader-info { flex: 1; }
  .leader-name { font-size: .75rem; font-weight: 900; text-transform: uppercase; }
  .leader-badges { display: flex; gap: .25rem; flex-wrap: wrap; margin-top: .2rem; }
  .badge-pill { font-size: .55rem; font-weight: 900; text-transform: uppercase; padding: .1rem .3rem; border-radius: 3px; display: inline-flex; align-items: center; gap: .2rem; }
  .leader-total { font-family: var(--mono); font-weight: 900; color: #818cf8; }

  /* breakdown */
  .breakdown-list { padding: 1rem 1.5rem; display: flex; flex-direction: column; gap: 1.25rem; }
  .breakdown-row { border-left: 4px solid; padding-left: 1rem; }
  .breakdown-name { font-size: .65rem; font-weight: 900; text-transform: uppercase; }
  .breakdown-total { font-size: .75rem; font-weight: 900; font-family: var(--mono); }
  .breakdown-detail { display: grid; grid-template-columns: repeat(3,1fr); gap: .25rem; margin-top: .3rem; font-size: .6rem; font-weight: 700; text-transform: uppercase; color: var(--slate4); }

  /* diner status */
  .diner-list { padding: 1rem 1.5rem; display: flex; flex-direction: column; gap: 1.25rem; }
  .diner-row { border-left: 4px solid; padding-left: 1rem; }
  .diner-name-row { display: flex; align-items: center; justify-content: space-between; }
  .diner-name { font-size: .65rem; font-weight: 900; text-transform: uppercase; }
  .diner-total-badge { font-size: .6rem; font-weight: 900; text-transform: uppercase; padding: .15rem .4rem; border: 2px solid; border-radius: 3px; }
  .item-tags { display: flex; flex-wrap: wrap; gap: .25rem; margin-top: .4rem; }
  .item-tag { font-size: .6rem; font-weight: 700; text-transform: uppercase; background: #f1f5f9; color: var(--slate4); padding: .15rem .4rem; border-radius: 3px; display: inline-flex; align-items: center; gap: .25rem; }
  .item-tag span { font-family: var(--mono); opacity: .6; }

  /* insights */
  .insights-grid { display: grid; grid-template-columns: 1fr 1fr; gap: .75rem; padding: 1rem 1.5rem 0; }
  .insight-cell { background: #f8fafc; border: 2px solid #f1f5f9; padding: .75rem; border-radius: 3px; }
  .insight-label { font-size: .6rem; font-weight: 900; text-transform: uppercase; color: var(--slate4); margin-bottom: .2rem; }
  .insight-val { font-size: .9rem; font-weight: 900; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .insight-sub { font-family: var(--mono); font-weight: 700; font-size: .75rem; color: #d97706; }
  .cat-bar-list { padding: .75rem 1.5rem 1.5rem; display: flex; flex-direction: column; gap: .6rem; }
  .cat-row-label { display: flex; justify-content: space-between; font-size: .6rem; font-weight: 900; text-transform: uppercase; margin-bottom: .2rem; }
  .cat-row-label span:last-child { color: var(--ink); }
  .cat-track { height: 6px; background: #f1f5f9; border-radius: 99px; overflow: hidden; }
  .cat-fill { height: 100%; border-radius: 99px; transition: width .5s ease; }
  .cat-fill.food { background: var(--orange); }
  .cat-fill.drink { background: var(--blue); }
  .cat-fill.dessert { background: var(--pink); }

  /* feedback */
  .feedback-card { border: 4px solid var(--ink); background: #fff; box-shadow: 10px 10px 0 var(--rose); }
  .star-row { display: flex; gap: .5rem; margin-top: .5rem; }
  .star-btn {
    width: 2.5rem; height: 2.5rem; border: 3px solid var(--ink); background: #fff;
    cursor: pointer; font-size: .85rem; font-weight: 900; display: flex; align-items: center; justify-content: center;
    transition: all .1s; font-family: var(--mono);
  }
  .star-btn.active { background: var(--yellow); transform: translate(-2px,-2px); box-shadow: 2px 2px 0 var(--ink); }
  textarea.feedback-ta { min-height: 120px; resize: none; font-size: .85rem; font-weight: 600; }
  .submit-btn {
    width: 100%; padding: 1.1rem; background: var(--ink); color: #fff;
    font-family: inherit; font-weight: 900; text-transform: uppercase; letter-spacing: .15em; font-size: .7rem;
    cursor: pointer; border: none; box-shadow: 6px 6px 0 var(--rose); transition: transform .1s, box-shadow .1s;
    display: flex; align-items: center; justify-content: center; gap: .5rem;
  }
  .submit-btn:hover { transform: translate(-1px,-1px); box-shadow: 7px 7px 0 var(--rose); }
  .submit-btn:active { transform: translate(3px,3px); box-shadow: none; }
  .submit-btn:disabled { opacity: .3; cursor: not-allowed; }
  .thanks-box { background: #fff1f2; border: 4px dashed var(--rose); padding: 2rem; text-align: center; display: flex; flex-direction: column; align-items: center; gap: .75rem; }
  .thanks-icon { width: 4rem; height: 4rem; background: var(--rose); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; animation: bounce 1s infinite; }
  @keyframes bounce { 0%,100%{transform:scale(1)}50%{transform:scale(1.15)} }
  .thanks-title { font-size: 1.1rem; font-weight: 900; text-transform: uppercase; }
  .thanks-sub { font-size: .6rem; font-weight: 800; text-transform: uppercase; color: var(--rose); letter-spacing: .1em; }

  /* footer */
  .app-footer { max-width: 1400px; margin: 0 auto; padding: 2rem 3rem; border-top: 4px solid var(--ink); display: flex; justify-content: space-between; align-items: center; font-size: .6rem; font-weight: 900; text-transform: uppercase; letter-spacing: .15em; color: var(--slate4); font-style: italic; }
  .footer-badge { background: var(--yellow); color: var(--ink); border: 2px solid var(--ink); box-shadow: 4px 4px 0 var(--ink); padding: .4rem .8rem; font-size: .6rem; font-weight: 900; text-transform: uppercase; letter-spacing: .1em; }
  .footer-right { text-align: right; }
  .footer-author { font-size: .55rem; font-weight: 900; color: var(--indigo); letter-spacing: .4em; margin-top: .4rem; }

  /* misc */
  .flex-col { display: flex; flex-direction: column; }
  .gap-sm { gap: .4rem; }
  .empty-msg { font-size: .65rem; font-weight: 700; text-transform: uppercase; color: var(--slate4); font-style: italic; text-align: center; padding: 1.5rem; }
  .form-field { margin-bottom: 1.25rem; }
  @media(max-width: 768px) {
    .header { padding: 1.5rem; flex-direction: column; align-items: flex-start; gap: 1rem; }
    .header-title { font-size: 3.5rem; }
    .main-grid { padding: 1.5rem; gap: 1.5rem; }
    .grand-value { font-size: 2.5rem; }
    .table-header, .item-row { grid-template-columns: 1fr 80px 160px; }
  }
</style>
</head>
<body>

<!-- ══════════ GATEWAY ══════════ -->
<div id="gateway">
  <div class="gateway-card">
    <div class="logo">SplitDash</div>
    <div class="logo-sub">✓ Powered by real-time sync</div>

    <div id="view-gateway" class="gateway-actions">
      <button class="btn btn-dark btn-block" onclick="showView('create')">
        <div>
          <div>Start New Group</div>
          <div class="gateway-sub">Generate a shareable code</div>
        </div>
        <span>＋</span>
      </button>
      <button class="btn btn-light btn-block" onclick="showView('join')">
        <div>
          <div>Join Existing</div>
          <div class="gateway-sub">Enter your friend's code</div>
        </div>
        <span>→</span>
      </button>
    </div>

    <div id="view-create" class="hide">
      <div class="form-field" style="margin-top:1.5rem">
        <label>Group Name</label>
        <input id="input-create-name" type="text" placeholder="e.g. Weekend Brunch" autofocus>
      </div>
      <div class="form-pair">
        <button class="btn btn-light" onclick="showView('gateway')">Back</button>
        <button class="btn btn-dark" onclick="createGroup()" style="flex:2">Register Group</button>
      </div>
      <span class="back-link" onclick="showView('gateway')">← Back</span>
    </div>

    <div id="view-join" class="hide">
      <div class="form-field" style="margin-top:1.5rem">
        <label>Group Access Code</label>
        <input id="input-join-code" type="text" placeholder="e.g. AX7B2R" style="font-family:var(--mono);font-size:1.8rem;text-transform:uppercase;letter-spacing:.15em">
      </div>
      <div class="form-pair">
        <button class="btn btn-light" onclick="showView('gateway')">Back</button>
        <button class="btn btn-dark" onclick="joinGroup()" style="flex:2">Sync Now</button>
      </div>
    </div>

    <div style="margin-top:2rem;padding-top:1.25rem;border-top:2px solid #f1f5f9;text-align:center">
      <p style="font-size:.6rem;font-weight:800;color:#cbd5e1;text-transform:uppercase;letter-spacing:.25em;font-style:italic">Produced by Disha Dutta</p>
    </div>
  </div>
</div>

<!-- ══════════ MAIN APP ══════════ -->
<div id="app">
  <header class="header">
    <div>
      <div>
        <span class="header-title">SplitDash</span>
        <span class="badge">V2.1 GROUP</span>
      </div>
      <div class="group-code" id="group-info">Loading...</div>
    </div>
    <div style="display:flex;flex-direction:column;align-items:flex-end;gap:.75rem">

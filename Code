<script>
// ══════════════════════════════════════════
// CONSTANTS
// ══════════════════════════════════════════
const ORDER_TIMEOUT_SEC = 120;
const SYNC_CHANNEL = 'split_dash_v2_sync';
const STORAGE_KEY = 'split_dash_session';
const COLORS = ['#F43F5E','#10B981','#3B82F6','#F59E0B','#8B5CF6','#EC4899','#06B6D4','#6366F1'];
const ADJECTIVES = ['Hungry','Thirsty','Vibrant','Chill','Happy','Spice','Classic','Epic'];
const NOUNS = ['Panda','Tiger','Falcon','Peacock','Ninja','Wizard','Elephant','Dino'];
const TAX_RATE = 0.05;
const TIP_RATE = 0.02;

const INITIAL_ITEMS = [
  {id:'1',name:'Butter Chicken',price:450,quantity:1,category:'food',claims:[],status:'unclaimed'},
  {id:'2',name:'Garlic Naan',price:60,quantity:3,category:'food',claims:[],status:'unclaimed'},
  {id:'3',name:'Paneer Tikka',price:320,quantity:1,category:'food',claims:[],status:'unclaimed'},
  {id:'4',name:'Kingfisher Blue',price:180,quantity:4,category:'drink',claims:[],status:'unclaimed'},
  {id:'5',name:'Masala Dosa',price:120,quantity:2,category:'food',claims:[],status:'unclaimed'},
  {id:'6',name:'Gulab Jamun (2pcs)',price:90,quantity:2,category:'dessert',claims:[],status:'unclaimed'},
  {id:'7',name:'Mineral Water',price:30,quantity:2,category:'drink',claims:[],status:'unclaimed'},
  {id:'8',name:'Chicken Biryani',price:480,quantity:1,category:'food',claims:[],status:'unclaimed'},
  {id:'9',name:'Mango Lassi',price:110,quantity:1,category:'drink',claims:[],status:'unclaimed'},
];

// ══════════════════════════════════════════
// STATE
// ══════════════════════════════════════════
function generateUser() {
  const adj = ADJECTIVES[Math.floor(Math.random()*ADJECTIVES.length)];
  const noun = NOUNS[Math.floor(Math.random()*NOUNS.length)];
  const color = COLORS[Math.floor(Math.random()*COLORS.length)];
  const id = crypto?.randomUUID ? crypto.randomUUID() : Math.random().toString(36).substr(2,11);
  return { id, name:`${adj}${noun}`, color, joinedAt:Date.now() };
}

let currentUser = (() => {
  try {
    const s = localStorage.getItem(`${STORAGE_KEY}_user`);
    if(s) return JSON.parse(s);
  } catch(e) {}
  const u = generateUser();
  localStorage.setItem(`${STORAGE_KEY}_user`, JSON.stringify(u));
  return u;
})();

let state = (() => {
  try {
    const s = localStorage.getItem(STORAGE_KEY);
    if(s) {
      const p = JSON.parse(s);
      return { ...p, taxRate: TAX_RATE, tipRate: TIP_RATE };
    }
  } catch(e) {}
  return {
    groupCode: null, groupName: null,
    items: INITIAL_ITEMS.map(i=>({...i, expirySeconds:ORDER_TIMEOUT_SEC})),
    users: [], taxRate: TAX_RATE, tipRate: TIP_RATE,
    history: [], sessionStartedAt: Date.now()
  };
})();

let history = state.history || [];
const MAX_HISTORY = 10;

let bc = null;

// ══════════════════════════════════════════
// GATEWAY / ROUTING
// ══════════════════════════════════════════
function showView(v) {
  document.getElementById('view-gateway').classList.add('hide');
  document.getElementById('view-create').classList.add('hide');
  document.getElementById('view-join').classList.add('hide');
  document.getElementById('view-'+v).classList.remove('hide');
}

function createGroup() {
  const name = document.getElementById('input-create-name').value.trim();
  if(!name) { alert('Please enter a group name'); return; }
  const code = Math.random().toString(36).substring(2,8).toUpperCase();
  state.groupCode = code;
  state.groupName = name;
  upsertUser(currentUser);
  saveState();
  initBroadcast();
  enterApp();
}

function joinGroup() {
  const code = document.getElementById('input-join-code').value.trim().toUpperCase();
  if(!code) { alert('Please enter a group code'); return; }
  state.groupCode = code;
  state.groupName = 'Joined Group';
  upsertUser(currentUser);
  saveState();
  initBroadcast();
  enterApp();
}

function enterApp() {
  document.getElementById('gateway').style.display = 'none';
  document.getElementById('app').style.display = 'block';
  render();
}

// ══════════════════════════════════════════
// BROADCAST / SYNC
// ══════════════════════════════════════════
function initBroadcast() {
  if(bc) bc.close();
  bc = new BroadcastChannel(SYNC_CHANNEL);
  bc.onmessage = (event) => {
    const { type, payload, senderId } = event.data;
    if(senderId === currentUser.id) return;
    const currentCode = state.groupCode;
    const incomingCode = payload?.groupCode;
    if(type !== 'HANDSHAKE_REQUEST' && incomingCode !== currentCode) return;
    if(type === 'HANDSHAKE_REQUEST') {
      if(state.groupCode) bc.postMessage({ type:'HANDSHAKE_RESPONSE', payload:state, timestamp:Date.now(), senderId:currentUser.id });
    } else if(type === 'HANDSHAKE_RESPONSE') {
      if(payload.groupCode === state.groupCode) { state = payload; render(); }
    } else if(type === 'USER_JOIN') {
      upsertUser(payload); render();
    } else if(type === 'UPDATE_STATE') {
      state = payload; render();
    }
  };
  bc.postMessage({ type:'HANDSHAKE_REQUEST', payload:null, timestamp:Date.now(), senderId:currentUser.id });
  bc.postMessage({ type:'USER_JOIN', payload:currentUser, timestamp:Date.now(), senderId:currentUser.id });
}

function syncBroadcast() {
  if(bc && state.groupCode) bc.postMessage({ type:'UPDATE_STATE', payload:state, timestamp:Date.now(), senderId:currentUser.id });
}

// ══════════════════════════════════════════
// STATE MUTATIONS
// ══════════════════════════════════════════
function precision(v) { return Math.round((v+Number.EPSILON)*100)/100; }

function saveHistory() {
  history = [{ items: JSON.parse(JSON.stringify(state.items)), timestamp:Date.now() }, ...history].slice(0, MAX_HISTORY);
}

function saveState() {
  state.history = history;
  try { localStorage.setItem(STORAGE_KEY, JSON.stringify(state)); } catch(e) {}
  syncBroadcast();
}

function upsertUser(user) {
  if(!state.users.find(u => u.id === user.id)) state.users.push(user);
}

function claimItem(itemId, amount) {
  const item = state.items.find(i => i.id === itemId);
  if(!item || item.status === 'locked') return;
  const totalValue = item.price * item.quantity;
  const claimedTotal = item.claims.reduce((a,c) => a+c.amount, 0);
  const remaining = precision(totalValue - claimedTotal);
  const existingClaim = item.claims.find(c => c.userId === currentUser.id);
  if(remaining <= 0 && !existingClaim) return;
  const claimAmount = (amount !== undefined) ? amount : (remaining > 0 ? remaining : 0);
  if(claimAmount <= 0) return;
  saveHistory();
  const idx = item.claims.findIndex(c => c.userId === currentUser.id);
  if(idx > -1) item.claims[idx].amount = precision(item.claims[idx].amount + claimAmount);
  else item.claims.push({ userId:currentUser.id, amount:claimAmount });
  const totalAfter = item.claims.reduce((a,c) => a+c.amount, 0);
  item.status = totalAfter >= totalValue ? 'claimed' : 'unclaimed';
  item.expirySeconds = ORDER_TIMEOUT_SEC;
  saveState(); render();
}

function unclaimItem(itemId) {
  const item = state.items.find(i => i.id === itemId);
  if(!item) return;
  saveHistory();
  item.claims = item.claims.filter(c => c.userId !== currentUser.id);
  item.status = 'unclaimed';
  item.expirySeconds = ORDER_TIMEOUT_SEC;
  saveState(); render();
}

function lockItem(itemId) {
  const item = state.items.find(i => i.id === itemId);
  if(!item) return;
  saveHistory();
  item.status = 'locked';
  saveState(); render();
}

function updateQuantity(itemId, qty) {
  const item = state.items.find(i => i.id === itemId);
  if(!item || item.status === 'locked') return;
  saveHistory();
  item.quantity = Math.max(1, qty);
  item.claims = []; item.status = 'unclaimed';
  saveState(); render();
}

function addItem(item) {
  saveHistory();
  state.items.push(item);
  saveState(); render();
}

function undoAction() {
  if(history.length === 0) return;
  const [last, ...rest] = history;
  history = rest;
  state.items = last.items;
  state.history = history;
  saveState(); render();
}

function autoSplit() {
  const unclaimed = state.items.filter(i => i.status === 'unclaimed');
  if(unclaimed.length === 0 || state.users.length === 0) { alert('No unclaimed items or no users in group.'); return; }
  saveHistory();
  state.items.forEach(item => {
    if(item.status !== 'unclaimed') return;
    const totalValue = item.price * item.quantity;
    const currentClaimed = item.claims.reduce((a,c) => a+c.amount, 0);
    const remaining = precision(totalValue - currentClaimed);
    if(remaining <= 0) return;
    const perUser = precision(remaining / state.users.length);
    state.users.forEach(user => {
      const idx = item.claims.findIndex(c => c.userId === user.id);
      if(idx > -1) item.claims[idx].amount = precision(item.claims[idx].amount + perUser);
      else item.claims.push({ userId:user.id, amount:perUser, isAutoSplit:true });
    });
    item.status = 'claimed';
  });
  saveState(); render();
}

function promptAddItem() {
  const name = prompt('Item Name?');
  if(!name) return;
  const priceStr = prompt('Price (₹)?');
  if(!priceStr) return;
  const price = Number(priceStr);
  if(isNaN(price) || price <= 0) { alert('Invalid price'); return; }
  addItem({ id: Math.random().toString(36).substr(2,9), name, price, quantity:1, category:'food', claims:[], status:'unclaimed', expirySeconds:ORDER_TIMEOUT_SEC });
}

// ══════════════════════════════════════════
// TICK
// ══════════════════════════════════════════
setInterval(() => {
  if(!state.groupCode) return;
  let changed = false;
  state.items.forEach(item => {
    if(item.status === 'locked') return;
    item.expirySeconds = Math.max(0, (item.expirySeconds||0) - 1);
    if(item.expirySeconds === 0 && item.claims.length > 0) {
      item.claims = []; item.status = 'unclaimed'; item.expirySeconds = ORDER_TIMEOUT_SEC; changed = true;
    }
  });
  if(changed) { saveState(); render(); }
  else renderExpiry();
}, 1000);

// ══════════════════════════════════════════
// TOTALS
// ══════════════════════════════════════════
function calcTotals() {
  const userBreakdowns = {};
  let totalSubtotal = 0;
  state.items.forEach(item => {
    totalSubtotal += item.price * item.quantity;
    item.claims.forEach(claim => {
      if(!userBreakdowns[claim.userId]) userBreakdowns[claim.userId] = { subtotal:0, tax:0, tip:0, total:0 };
      userBreakdowns[claim.userId].subtotal += claim.amount;
    });
  });
  const taxAmount = totalSubtotal * state.taxRate;
  const tipAmount = totalSubtotal * state.tipRate;
  Object.keys(userBreakdowns).forEach(uid => {
    const sub = userBreakdowns[uid].subtotal;
    const prop = totalSubtotal === 0 ? 0 : sub / totalSubtotal;
    userBreakdowns[uid].tax = prop * taxAmount;
    userBreakdowns[uid].tip = prop * tipAmount;
    userBreakdowns[uid].total = sub + userBreakdowns[uid].tax + userBreakdowns[uid].tip;
  });
  const settledCount = state.items.filter(i => i.status === 'locked').length;
  const settledProgress = state.items.length === 0 ? 0 : settledCount / state.items.length;
  return { userBreakdowns, totalSubtotal, taxAmount, tipAmount, grandTotal: totalSubtotal+taxAmount+tipAmount, settledProgress };
}

// ══════════════════════════════════════════
// RENDER
// ══════════════════════════════════════════
function getUserColor(userId) {
  const u = state.users.find(u => u.id === userId);
  return u ? u.color : '#888';
}
function getUserName(userId) {
  const u = state.users.find(u => u.id === userId);
  return u ? u.name : '??';
}

function renderItems() {
  const list = document.getElementById('item-list');
  list.innerHTML = '';
  state.items.forEach(item => {
    const totalValue = item.price * item.quantity;
    const claimedTotal = item.claims.reduce((a,c) => a+c.amount, 0);
    const myClaim = item.claims.find(c => c.userId === currentUser.id);
    const isLocked = item.status === 'locked';

    const row = document.createElement('div');
    row.className = 'item-row' + (isLocked ? ' locked' : '');
    row.id = 'row-' + item.id;

    // Category bar
    const catBar = document.createElement('div');
    catBar.className = 'cat-bar cat-' + item.category;
    row.appendChild(catBar);

    // Col 1: name + qty
    const col1 = document.createElement('div');
    col1.innerHTML = `
      <div style="display:flex;align-items:center;flex-wrap:wrap;gap:.3rem">
        <span class="item-name ${isLocked?'struck':''}">${item.name}</span>
        <span class="qty-controls">
          <button class="qty-btn" onclick="updateQuantity('${item.id}',${item.quantity-1})" ${isLocked?'disabled':''}>−</button>
          <span class="qty-tag">${item.quantity}x</span>
          <button class="qty-btn" onclick="updateQuantity('${item.id}',${item.quantity+1})" ${isLocked?'disabled':''}>+</button>
        </span>
      </div>
      <div class="claim-avatars" id="avatars-${item.id}"></div>
    `;
    row.appendChild(col1);

    // Col 2: price
    const col2 = document.createElement('div');
    col2.className = 'price-col';
    col2.innerHTML = `<div class="price-main">₹${totalValue}</div><div class="price-ea">₹${item.price}/ea</div>`;
    row.appendChild(col2);

    // Col 3: actions
    const col3 = document.createElement('div');
    col3.className = 'action-col';
    if(isLocked) {
      col3.innerHTML = `<div class="locked-tag">🔒 Locked</div>`;
    } else if(!myClaim) {
      col3.innerHTML = `
        <div class="action-btns">
          <button class="claim-btn btn-claim-full" onclick="claimItem('${item.id}')">Full</button>
          <button class="claim-btn btn-claim-split" onclick="toggleSplit('${item.id}')" style="border:3px solid var(--ink)">Split</button>
        </div>
        <div class="split-popup hide" id="split-${item.id}">
          <label>Partial Amount (₹)</label>
          <div class="split-popup-inner">
            <input type="number" id="split-amt-${item.id}" placeholder="Amount" min="1" max="${totalValue}" style="flex:1">
            <button class="btn-xs" onclick="claimPartial('${item.id}')">Add</button>
          </div>
        </div>
      `;
    } else {
      col3.innerHTML = `
        <div class="claimed-tag">₹${myClaim.amount} Claimed ✓</div>
        <div class="action-btns" style="margin-top:.3rem">
          <button class="btn-undo-small" onclick="unclaimItem('${item.id}')">Undo</button>
          <button class="btn-lock-small" onclick="lockItem('${item.id}')">Lock</button>
        </div>
      `;
    }
    row.appendChild(col3);
    list.appendChild(row);

    // Claim avatars
    const avatarWrap = document.getElementById('avatars-'+item.id);
    item.claims.forEach(claim => {
      const name = getUserName(claim.userId);
      const color = getUserColor(claim.userId);
      const av = document.createElement('div');
      av.className = 'mini-avatar';
      av.style.background = color;
      av.title = `${name}: ₹${claim.amount}`;
      av.textContent = name.slice(0,2);
      avatarWrap.appendChild(av);
    });
    if(item.status === 'unclaimed' && (item.expirySeconds||0) < 30 && item.expirySeconds > 0 && item.claims.length > 0) {
      const warn = document.createElement('span');
      warn.className = 'expiry-warn';
      warn.id = 'expiry-'+item.id;
      warn.innerHTML = `⚠ Expires in ${item.expirySeconds}s`;
      avatarWrap.appendChild(warn);
    }
  });
}

function renderExpiry() {
  state.items.forEach(item => {
    const el = document.getElementById('expiry-'+item.id);
    if(el) el.textContent = `⚠ Expires in ${item.expirySeconds}s`;
  });
}

function toggleSplit(itemId) {
  const popup = document.getElementById('split-'+itemId);
  if(popup) popup.classList.toggle('hide');
}

function claimPartial(itemId) {
  const input = document.getElementById('split-amt-'+itemId);
  const amount = Number(input.value);
  if(!isNaN(amount) && amount > 0) { claimItem(itemId, amount); }
  const popup = document.getElementById('split-'+itemId);
  if(popup) popup.classList.add('hide');
}

function renderTotals() {
  const t = calcTotals();
  document.getElementById('tot-subtotal').textContent = '₹'+t.totalSubtotal.toFixed(0);
  document.getElementById('lbl-gst').textContent = `GST (${(state.taxRate*100).toFixed(0)}%)`;
  document.getElementById('tot-gst').textContent = '₹'+t.taxAmount.toFixed(0);
  document.getElementById('lbl-svc').textContent = `Service Fee (${(state.tipRate*100).toFixed(0)}%)`;
  document.getElementById('tot-svc').textContent = '₹'+t.tipAmount.toFixed(0);
  document.getElementById('tot-grand').textContent = '₹'+t.grandTotal.toFixed(0);

  // Progress ring
  const progress = t.settledProgress;
  const circumference = 226.2;
  const offset = circumference - progress * circumference;
  const ringFill = document.getElementById('ring-fill');
  if(ringFill) ringFill.setAttribute('stroke-dashoffset', offset.toFixed(1));
  const ringPct = document.getElementById('ring-pct-text');
  if(ringPct) ringPct.textContent = Math.round(progress*100)+'%';
  const settledAmt = document.getElementById('settled-amount');
  if(settledAmt) settledAmt.textContent = '₹'+(t.grandTotal*progress).toFixed(0);

  // Breakdown
  const breakdownList = document.getElementById('breakdown-list');
  breakdownList.innerHTML = '';
  state.users.forEach(user => {
    const b = t.userBreakdowns[user.id] || { subtotal:0, tax:0, tip:0, total:0 };
    const row = document.createElement('div');
    row.className = 'breakdown-row';
    row.style.borderLeftColor = user.color;
    row.innerHTML = `
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:.3rem">
        <span class="breakdown-name">${user.name}</span>
        <span class="breakdown-total">₹${b.total.toFixed(0)}</span>
      </div>
      <div class="breakdown-detail">
        <div>Sub: ₹${b.subtotal.toFixed(0)}</div>
        <div>GST: ₹${b.tax.toFixed(0)}</div>
        <div>SVC: ₹${b.tip.toFixed(0)}</div>
      </div>
    `;
    breakdownList.appendChild(row);
  });
  if(state.users.length === 0) breakdownList.innerHTML = '<div class="empty-msg">No claims yet.</div>';

  // Leaderboard
  const leaders = [...state.users].sort((a,b) => (t.userBreakdowns[b.id]?.total||0)-(t.userBreakdowns[a.id]?.total||0));
  const leaderList = document.getElementById('leader-list');
  leaderList.innerHTML = '';
  if(leaders.length === 0) { leaderList.innerHTML = '<div class="empty-msg" style="color:rgba(255,255,255,.3)">Waiting for group members...</div>'; }
  leaders.slice(0,3).forEach((user,idx) => {
    const total = t.userBreakdowns[user.id]?.total||0;
    const badges = getBadges(user, t.userBreakdowns);
    const row = document.createElement('div');
    row.className = 'leader-row';
    row.innerHTML = `
      <div class="leader-rank">#${idx+1}</div>
      <div class="leader-info">
        <div class="leader-name">${user.name}</div>
        <div class="leader-badges">${badges.map(b=>`<span class="badge-pill ${b.cls}">${b.label}</span>`).join('')}</div>
      </div>
      <div class="leader-total">₹${total.toFixed(0)}</div>
    `;
    leaderList.appendChild(row);
  });

  // Diner status
  const dinerList = document.getElementById('diner-list');
  dinerList.innerHTML = '';
  if(state.users.length === 0) { dinerList.innerHTML = '<div class="empty-msg">Waiting for users...</div>'; }
  state.users.forEach(user => {
    const userTotal = t.userBreakdowns[user.id] || { total:0 };
    const userOrders = state.items.filter(i => i.claims.some(c => c.userId === user.id));
    const row = document.createElement('div');
    row.className = 'diner-row';
    row.style.borderLeftColor = user.color;
    const hasClaims = userTotal.total > 0;
    row.innerHTML = `
      <div class="diner-name-row">
        <span class="diner-name">${user.name}</span>
        <span class="diner-total-badge" style="${hasClaims?'background:#eef2ff;border-color:#a5b4fc;color:#4338ca':'background:#f8fafc;border-color:#e2e8f0;color:#94a3b8'}">₹${userTotal.total.toFixed(0)}</span>
      </div>
      <div class="item-tags">
        ${userOrders.length > 0 ? userOrders.map(item => {
          const amt = item.claims.find(c=>c.userId===user.id)?.amount||0;
          return `<span class="item-tag">${item.name} <span>₹${amt}</span></span>`;
        }).join('') : '<span style="font-size:.65rem;font-style:italic;color:var(--slate4)">No items claimed yet...</span>'}
      </div>
    `;
    dinerList.appendChild(row);
  });

  // Insights
  const items = state.items;
  const total = items.reduce((a,i) => a+i.price*i.quantity, 0);
  const avg = total / (items.length||1);
  const mostExp = items.reduce((p,c) => (p.price*p.quantity > c.price*c.quantity) ? p : c, items[0]);
  const ig = document.getElementById('insights-grid');
  ig.innerHTML = mostExp ? `
    <div class="insight-cell">
      <div class="insight-label">Most Expensive</div>
      <div class="insight-val">${mostExp.name}</div>
      <div class="insight-sub">₹${mostExp.price*mostExp.quantity}</div>
    </div>
    <div class="insight-cell">
      <div class="insight-label">Average Item</div>
      <div class="insight-val">Cost/Type</div>
      <div class="insight-sub">₹${avg.toFixed(0)}</div>
    </div>
  ` : '';
  const catMap = {};
  items.forEach(i => { catMap[i.category] = (catMap[i.category]||0) + i.price*i.quantity; });
  const catBars = document.getElementById('cat-bar-list');
  catBars.innerHTML = Object.entries(catMap).map(([cat,val]) => `
    <div>
      <div class="cat-row-label"><span style="color:var(--slate4)">${cat}</span><span>₹${val.toFixed(0)}</span></div>
      <div class="cat-track"><div class="cat-fill ${cat}" style="width:${(total?val/total*100:0).toFixed(1)}%"></div></div>
    </div>
  `).join('');
}

function renderHeader() {
  document.getElementById('group-info').innerHTML = `${state.groupName} // Code: <span>${state.groupCode}</span>`;
  document.getElementById('sync-id').textContent = 'Sync ID: '+SYNC_CHANNEL;
  document.getElementById('live-badge-text').textContent = `${state.users.length} Active in ${state.groupName}`;

  const stack = document.getElementById('avatar-stack');
  stack.innerHTML = '';
  state.users.forEach((u,i) => {
    const av = document.createElement('div');
    av.className = 'avatar';
    av.style.cssText = `background:${u.color};z-index:${10-i}`;
    av.title = u.name;
    av.textContent = u.name.slice(0,2);
    stack.appendChild(av);
  });
}

function getBadges(user, userBreakdowns) {
  const badges = [];
  const stats = userBreakdowns[user.id]||{total:0};
  if(user.name.toLowerCase().includes('chill')&&user.name.toLowerCase().includes('falcon'))
    badges.push({ label:'👑 Alpha Falcon', cls:'badge-pill' });
  if(stats.total > 1000) badges.push({ label:'💰 Big Spender', cls:'badge-pill' });
  const userClaims = state.items.filter(i => i.claims.some(c => c.userId===user.id));
  const cats = userClaims.map(i => i.category);
  if(cats.filter(c=>c==='drink').length >= 3) badges.push({ label:'🍺 Hydrated', cls:'badge-pill' });
  if(cats.filter(c=>c==='food').length >= 4) badges.push({ label:'🍕 Feaster', cls:'badge-pill' });
  if(userClaims.length > 0 && Math.min(...userClaims.map(i=>i.expirySeconds||999)) > 110)
    badges.push({ label:'✨ Fast Fingers', cls:'badge-pill' });
  return badges;
}

function render() {
  renderHeader();
  renderItems();
  renderTotals();
}


// FEEDBACK
// ══════════════════════════════════════════
let feedbackRating = 0;

function setStar(n) {
  feedbackRating = n;
  document.querySelectorAll('.star-btn').forEach(btn => {
    btn.classList.toggle('active', Number(btn.dataset.star) <= n);
  });
  updateSubmitBtn();
}

function updateSubmitBtn() {
  const ta = document.getElementById('feedback-ta');
  const btn = document.getElementById('submit-btn');
  if(btn) btn.disabled = !(ta && ta.value.trim() && feedbackRating > 0);
}

document.addEventListener('DOMContentLoaded', () => {
  const ta = document.getElementById('feedback-ta');
  if(ta) ta.addEventListener('input', updateSubmitBtn);
});

function submitFeedback() {
  const ta = document.getElementById('feedback-ta');
  if(!ta.value.trim() || feedbackRating === 0) return;
  const body = document.getElementById('feedback-body');
  body.innerHTML = `
    <div class="thanks-box">
      <div class="thanks-icon">❤️</div>
      <div class="thanks-title">Sweet Feedback Received!</div>
      <div class="thanks-sub">Disha Dutta will review this soon.</div>
    </div>
  `;
  setTimeout(() => {
    feedbackRating = 0;
    body.innerHTML = `
      <div class="form-field">
        <label>How was the experience?</label>
        <div class="star-row" id="star-row">
          <button class="star-btn" data-star="1" onclick="setStar(1)">1</button>
          <button class="star-btn" data-star="2" onclick="setStar(2)">2</button>
          <button class="star-btn" data-star="3" onclick="setStar(3)">3</button>
          <button class="star-btn" data-star="4" onclick="setStar(4)">4</button>
          <button class="star-btn" data-star="5" onclick="setStar(5)">5</button>
        </div>
      </div>
      <div class="form-field">
        <label>Details (Suggestions / Bugs)</label>
        <textarea class="feedback-ta" id="feedback-ta" placeholder="Ex: The auto-split logic for 3 people was slightly off..."></textarea>
      </div>
      <button class="submit-btn" id="submit-btn" onclick="submitFeedback()" disabled>✉ Send to Disha</button>
    `;
    document.getElementById('feedback-ta').addEventListener('input', updateSubmitBtn);
  }, 5000);
}

